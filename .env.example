# =============================================================
# HNIVision — API credentials template
# Copy this file to `.env` and fill in your own keys.
# NEVER commit `.env` to git (it's already in .gitignore).
# =============================================================

# --- Method 1: Image labeling (Google Vision API) ---
# Get a service account JSON key from:
#   https://console.cloud.google.com/iam-admin/serviceaccounts
# Then set the absolute path to that JSON file:
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/your-service-account.json

# --- Method 5: Vision-LLM (OpenAI GPT-4o) ---
# Get a key from:
#   https://platform.openai.com/api-keys
# Recommended: scope the key to a project with usage limits.
OPENAI_API_KEY=sk-proj-...

# Optional: override the default VLM model
HNIVISION_VLM_MODEL=gpt-4o

# --- Cache & storage paths ---
# Where to cache downloaded model weights (default: ~/.cache/hnivision)
# HNIVISION_CACHE_DIR=/path/to/cache

# Where to store benchmark dataset (default: ./data)
# HNIVISION_DATA_DIR=/path/to/data

# --- Methods 2, 3, 4 (Classification, Detection, Segmentation) ---
# These run fully offline and require no API keys.
# Model weights download automatically on first use.
